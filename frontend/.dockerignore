# Dependencies — reinstalled fresh via npm ci in the image
node_modules/

# Build output — regenerated by npm run build in the image
dist/

# Test infrastructure — not part of the build
vitest.config.ts
src/test/
src/**/__tests__/

# Tool caches — not needed in the image
.pytest_cache/

# Local dev tooling — not needed in the image
.nvmrc
Makefile
scripts/

# VCS
.gitignore
