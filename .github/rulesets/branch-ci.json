{
  "name": "Require CI green before merge",
  "target": "branch",
  "enforcement": "active",
  "conditions": {
    "ref_name": {
      "include": ["refs/heads/main"],
      "exclude": []
    }
  },
  "rules": [
    {
      "type": "required_status_checks",
      "parameters": {
        "strict_required_status_checks_policy": false,
        "required_status_checks": [
          { "context": "Backend lint" },
          { "context": "Backend tests" },
          { "context": "Frontend lint" },
          { "context": "Frontend tests" },
          { "context": "Build backend image" },
          { "context": "Build frontend image" }
        ]
      }
    }
  ],
  "bypass_actors": []
}
