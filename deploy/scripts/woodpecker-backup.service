[Unit]
Description=Woodpecker daily PostgreSQL backup to S3
After=docker.service network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=ubuntu
WorkingDirectory=/opt/woodpecker
ExecStart=/usr/bin/docker compose -f docker-compose.yml -f docker-compose-prod.yml --profile backup run --rm backup
StandardOutput=journal
StandardError=journal
SyslogIdentifier=woodpecker-backup
