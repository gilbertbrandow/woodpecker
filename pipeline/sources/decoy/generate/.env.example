# Lichess personal access token — required for Lichess game URL resolution
# Generate at: https://lichess.org/account/oauth/token (no special scopes needed)
LICHESS_TOKEN=lip_xxxxxxxxxxxxxxxxxxxx

# HuggingFace token — optional if you've run `huggingface-cli login`
# Generate at: https://huggingface.co/settings/tokens
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxx
