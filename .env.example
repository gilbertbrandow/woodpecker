# Copy this file to .env for local development. Values below work as-is for local testing.
# .env is loaded automatically by Docker Compose. Never commit .env to git.

# Postgres
POSTGRES_DB=woodpecker
POSTGRES_USER=woodpecker
POSTGRES_PASSWORD=woodpecker

# Flask
SECRET_KEY=dev-secret-key-change-in-production

LICHESS_CLIENT_ID=woodpecker-dev
LICHESS_REDIRECT_URI=http://localhost:5173/api/auth/callback

# Frontend origin (used by Flask for CORS / cookie config)
APP_ORIGIN=http://localhost:5173

# Sentry — leave empty to disable error tracking locally
SENTRY_DSN=
VITE_SENTRY_DSN=
